# ======================================
# B站缓存转换工具 专属忽略规则
# ======================================
# 真实环境配置文件（仅提交 .env.example）
.env

# 视频输出目录（大文件，不提交）
converted/

# 程序生成的缓存/备份文件
*.m4s.bak
*_temp.m4s

# FFmpeg 便携程序（不提交二进制文件）
ffmpeg.exe
ffmpeg
ffplay.exe
ffprobe.exe

# ======================================
# Python 通用忽略规则
# ======================================
# 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# 分布式编译文件
*.so

# 虚拟环境
.venv/
venv/
env/
ENV/

# 编辑器/IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 系统垃圾文件
.DS_Store
Thumbs.db

# 日志文件
*.log

# 文档
docs/